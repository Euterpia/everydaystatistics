---
interface Props {
  variant?: 'hero' | 'unit';
}
const { variant = 'unit' } = Astro.props;
---

<div class={`signup-form signup-form--${variant}`}>
  {variant === 'hero' ? (
    <>
      <h2 class="signup-form__heading">Get one unit a day for 44 days.</h2>
      <p class="signup-form__sub">Free. No spam. Unsubscribe any time. Each email is one complete unit from the curriculum — nothing added, nothing removed.</p>
    </>
  ) : (
    <>
      <h2 class="signup-form__heading">Continue by email</h2>
      <p class="signup-form__sub">Get one unit delivered to your inbox every day for 44 days. Free. No spam. Unsubscribe any time.</p>
    </>
  )}
  <form class="signup-form__form" action="/api/subscribe" method="POST">
    <div class="signup-form__fields">
      <input
        class="signup-form__input"
        type="email"
        name="email"
        placeholder="your@email.com"
        required
        autocomplete="email"
        aria-label="Email address"
      />
      <button class="signup-form__btn" type="submit">
        Start the course
      </button>
    </div>
    <p class="signup-form__note">44 units · one per day · free forever</p>
  </form>
</div>
