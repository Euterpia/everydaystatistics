---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import TierBadge from '../../components/TierBadge.astro';
import BayesBadge from '../../components/BayesBadge.astro';
import SignupForm from '../../components/SignupForm.astro';

export async function getStaticPaths() {
  const units = await getCollection('units');
  units.sort((a, b) => {
    const [aArea, aUnit] = a.data.unitId.split('.').map(Number);
    const [bArea, bUnit] = b.data.unitId.split('.').map(Number);
    return aArea !== bArea ? aArea - bArea : aUnit - bUnit;
  });
  return units.map((unit, index) => ({
    params: { slug: unit.data.unitId.replace('.', '-') },
    props: {
      unit,
      prev: units[index - 1] ?? null,
      next: units[index + 1] ?? null,
    },
  }));
}

const { unit, prev, next } = Astro.props;
const { Content } = await render(unit);

const areaNames: Record<number, string> = {
  0: 'Level 0',
  1: 'Area 1',
  2: 'Area 2',
  3: 'Area 3',
  4: 'Area 4',
};
const areaLabel = unit.data.areaName
  ? unit.data.areaName.split(':')[0].trim()
  : (areaNames[unit.data.area] ?? `Area ${unit.data.area}`);

function slugify(id: string) { return id.replace('.', '-'); }

const canonicalUrl = `https://everydaystatistics.com/unit/${slugify(unit.data.unitId)}/`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": ["Article", "LearningResource"],
  "headline": unit.data.title,
  "description": unit.data.summary,
  "url": canonicalUrl,
  "inLanguage": "en-GB",
  "educationalLevel": unit.data.area === 0 ? "Beginner" : unit.data.area <= 2 ? "Intermediate" : "Advanced",
  "learningResourceType": "Article",
  "teaches": unit.data.title,
  "isPartOf": {
    "@type": "Course",
    "name": "Everyday Statistics",
    "url": "https://everydaystatistics.com/curriculum/",
    "provider": { "@type": "Organization", "name": "Everyday Statistics", "url": "https://everydaystatistics.com" }
  },
  "author": { "@type": "Person", "name": "David Mackay" },
  "publisher": { "@type": "Organization", "name": "Everyday Statistics", "url": "https://everydaystatistics.com" },
  "timeRequired": `PT${unit.data.duration}M`,
  ...(unit.data.prerequisites.length > 0 && {
    "competencyRequired": unit.data.prerequisites.map(id => `https://everydaystatistics.com/unit/${slugify(id)}/`)
  }),
};
---

<Base title={unit.data.title} description={unit.data.summary}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <div class="eds-main eds-main--narrow">

    <header class="eds-lessonheader">
      <div class="eyebrow">Unit {unit.data.unitId} · {areaLabel}</div>
      <h1>{unit.data.title}</h1>
      <p class="lede">{unit.data.summary}</p>
      <div class="eds-lessonheader__meta">
        <span class="chip chip--source">Reading time · {unit.data.duration} min</span>
        <TierBadge tier={unit.data.tier ?? undefined} />
        <BayesBadge encounter={unit.data.bayesEncounter} />
        {unit.data.draft && <span class="chip chip--draft">In progress</span>}
      </div>
      {unit.data.prerequisites.length > 0 && (
        <div class="eds-lessonheader__prereqs">
          <span>Requires:</span>
          {unit.data.prerequisites.map(prereqId => (
            <a href={`/unit/${slugify(prereqId)}`}>Unit {prereqId}</a>
          ))}
        </div>
      )}
    </header>

    <article class="prose eds-prose">
      <Content />
    </article>

    {unit.data.draft && (
      <div class="eds-stub">
        <p style="font-weight: 600;">Full content coming soon.</p>
        <p>This unit is part of the curriculum skeleton. The complete explainer, interactive visualisation, and detection challenge will be added here.</p>
      </div>
    )}

    <SignupForm variant="unit" />

    <nav class="eds-lessonnav" aria-label="Unit navigation">
      <div class="eds-lessonnav__grid">
        {prev ? (
          <a href={`/unit/${slugify(prev.data.unitId)}`} class="eds-lessonnav__item">
            <div class="eds-lessonnav__dir">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="15 6 9 12 15 18"/>
              </svg>
              Previous
            </div>
            <div class="eds-lessonnav__title">{prev.data.title}</div>
            <div class="eds-lessonnav__id">Unit {prev.data.unitId}</div>
          </a>
        ) : (
          <div class="eds-lessonnav__item--empty" aria-hidden="true"></div>
        )}
        {next ? (
          <a href={`/unit/${slugify(next.data.unitId)}`} class="eds-lessonnav__item eds-lessonnav__item--next">
            <div class="eds-lessonnav__dir">
              Next
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="9 6 15 12 9 18"/>
              </svg>
            </div>
            <div class="eds-lessonnav__title">{next.data.title}</div>
            <div class="eds-lessonnav__id">Unit {next.data.unitId}</div>
          </a>
        ) : (
          <a href="/reference" class="eds-lessonnav__item eds-lessonnav__item--next">
            <div class="eds-lessonnav__dir">You've finished the curriculum</div>
            <div class="eds-lessonnav__title">Browse the reference library</div>
          </a>
        )}
      </div>
    </nav>

  </div>
</Base>
