---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import TierBadge from '../components/TierBadge.astro';
import BayesBadge from '../components/BayesBadge.astro';

const allUnits = await getCollection('units');

// Sort by unitId numerically: "0.1" < "0.2" < "1.1" etc.
allUnits.sort((a, b) => {
  const [aArea, aUnit] = a.data.unitId.split('.').map(Number);
  const [bArea, bUnit] = b.data.unitId.split('.').map(Number);
  return aArea !== bArea ? aArea - bArea : aUnit - bUnit;
});

const areas = [
  { id: 0, label: 'Level 0', title: 'Zero-Knowledge On-Ramp', desc: 'No prior knowledge required. Five units to build the basic vocabulary.' },
  { id: 1, label: 'Area 1', title: 'Foundations', desc: 'Probability, uncertainty, and the laws of chance.' },
  { id: 2, label: 'Area 2', title: 'Measurement and Its Limits', desc: 'The formal toolkit — sampling, distributions, confidence, p-values.' },
  { id: 3, label: 'Area 3', title: 'Applied Detection', desc: 'Twelve tricks used in the wild, with real examples and detection tests.' },
  { id: 4, label: 'Area 4', title: 'The Anti-Curriculum', desc: 'Cognitive failure modes and their corrections. Ends with Bayes as the synthesis.' },
];

function slugify(id: string) {
  return id.replace('.', '-');
}
---

<Base
  title="Curriculum"
  description="The full Everyday Statistics curriculum — 44 units across five areas, from zero prior knowledge to statistical self-defence."
>
  <div class="container" style="padding-top: 3rem; padding-bottom: 5rem;">

    <div style="max-width: 640px; margin-bottom: 3rem;">
      <h1 style="font-size: var(--text-3xl); font-weight: 800; letter-spacing: -0.025em; margin-bottom: 1rem;">
        The Curriculum
      </h1>
      <p style="font-size: var(--text-lg); color: var(--text-muted); line-height: 1.7;">
        44 units. One per day, fifteen minutes each. Ten weeks to statistical self-defence.
        Follow the sequence or jump to any unit from the reference library.
      </p>
      <div style="display: flex; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap;">
        <div style="display: flex; align-items: center; gap: 0.4rem; font-size: var(--text-sm);">
          <span class="badge badge--tier-1">★ Essential</span>
          <span style="color: var(--text-muted);">Tier 1 — highest Pareto return</span>
        </div>
        <div style="display: flex; align-items: center; gap: 0.4rem; font-size: var(--text-sm);">
          <span class="badge badge--tier-2">◆ Powerful</span>
          <span style="color: var(--text-muted);">Tier 2 — strong return</span>
        </div>
        <div style="display: flex; align-items: center; gap: 0.4rem; font-size: var(--text-sm);">
          <span class="badge badge--bayes">⬡ Bayes</span>
          <span style="color: var(--text-muted);">Bayes thread</span>
        </div>
      </div>
    </div>

    {areas.map(area => {
      const units = allUnits.filter(u => u.data.area === area.id);
      return (
        <section class="area-section">
          <div class="area-header" data-area={area.id}>
            <div>
              <div class="area-header__label">{area.label} · {units.length} units</div>
              <div class="area-header__title">{area.title}</div>
              <div class="area-header__desc">{area.desc}</div>
            </div>
          </div>
          <div class="unit-list">
            {units.map(unit => (
              <a
                href={`/unit/${slugify(unit.data.unitId)}`}
                class="unit-card"
                data-area={unit.data.area}
              >
                <div class="unit-card__id">{unit.data.unitId}</div>
                <div>
                  <div class="unit-card__title">{unit.data.title}</div>
                  <div class="unit-card__meta">
                    {unit.data.tier && <TierBadge tier={unit.data.tier} />}
                    {unit.data.bayesEncounter && <BayesBadge encounter={unit.data.bayesEncounter} />}
                    <span class="unit-card__duration">{unit.data.duration} min</span>
                  </div>
                </div>
                <p class="unit-card__summary">{unit.data.summary}</p>
              </a>
            ))}
          </div>
        </section>
      );
    })}

  </div>
</Base>
