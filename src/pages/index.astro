---
import Base from '../layouts/Base.astro';
import SignupForm from '../components/SignupForm.astro';
---

<Base title="Everyday Statistics">

  <div class="eds-main" style="max-width: 960px;">

    <section class="eds-hero">
      <div class="eds-hero__left">
        <div class="eyebrow">A free public site</div>
        <h1 class="eds-hero__title">
          How to read a number<br/>
          <em>without being lied to.</em>
        </h1>
        <p class="lede eds-hero__lede">
          Statistics are how power is justified, sold, and quietly imposed. This site teaches
          you the moves — slowly, plainly, with worked examples — so you can spot the trick
          before the trick gets you.
        </p>
        <div class="eds-hero__ctas">
          <a href="/unit/0-1" class="btn btn--primary">
            Start with unit 0.1
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 6 15 12 9 18"/>
            </svg>
          </a>
          <a href="/curriculum" class="btn btn--secondary">
            See the curriculum
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 6 15 12 9 18"/>
            </svg>
          </a>
        </div>
        <div class="eds-hero__meta">
          <p class="caption">No login. No paywall. No tracking. Built by one person.</p>
        </div>
      </div>

      <aside class="eds-hero__right">
        <div class="eds-feature">
          <div class="eds-feature__chip">From unit 2.1</div>
          <div class="eds-feature__quote">
            "The average UK household has £20,800 in savings."
          </div>
          <div class="eds-feature__caption">
            Imagine ten people. Nine have £400. One has £200,000. The average is now
            £20,040: technically true, practically useless, and exactly the kind of number
            that ends up in a headline.
          </div>
          <div class="eds-feature__rule"></div>
          <div class="eds-feature__source">Source · ONS Wealth &amp; Assets Survey, 2024</div>
        </div>
      </aside>
    </section>

    <section class="eds-pillars">
      <div class="eyebrow">What you'll learn</div>
      <h2>Four areas. One clear path.</h2>
      <div class="eds-pillars__grid">
        <div class="eds-pillar">
          <div class="eds-pillar__num">Level 0</div>
          <h3>The zero-knowledge on-ramp.</h3>
          <p>Big numbers, percentages, the three averages, reading graphs. Five units. No prior knowledge required.</p>
        </div>
        <div class="eds-pillar">
          <div class="eds-pillar__num">Area 1</div>
          <h3>Foundations.</h3>
          <p>Probability, uncertainty, and the laws of chance. The bedrock before any formal apparatus.</p>
        </div>
        <div class="eds-pillar">
          <div class="eds-pillar__num">Area 2</div>
          <h3>Measurement and its limits.</h3>
          <p>Distributions, sampling, confidence intervals, p-values. The formal toolkit, taught properly.</p>
        </div>
        <div class="eds-pillar">
          <div class="eds-pillar__num">Area 3</div>
          <h3>Applied detection.</h3>
          <p>Twelve tricks used in medicine, politics, and finance — with real examples and a detection test for each.</p>
        </div>
        <div class="eds-pillar">
          <div class="eds-pillar__num">Area 4</div>
          <h3>The anti-curriculum.</h3>
          <p>How human beings fail at statistical reasoning, and the correction for each failure. Ends with Bayes.</p>
        </div>
      </div>
    </section>

    <section class="eds-pull">
      <blockquote class="pullquote">
        The point isn't to make you suspicious of every number. It's to make you suspicious
        of the right ones — and to give you back the calm of knowing which is which.
      </blockquote>
    </section>

    <SignupForm variant="hero" />

  </div>

</Base>
