---
import Base from '../layouts/Base.astro';
const error = Astro.url.searchParams.get('error');
---

<Base title="You're signed up — Everyday Statistics">
  <div class="eds-main eds-main--narrow">
    <div class="eds-subscribed">

      {error ? (
        <>
          <div class="eyebrow">Something went wrong</div>
          <h1>Try again.</h1>
          {error === 'invalid' ? (
            <p>That doesn't look like a valid email address. Please go back and try again.</p>
          ) : (
            <p>
              There was a problem processing your signup. Please try again in a moment, or email
              <a class="link" href="mailto:hello@everydaystatistics.com">hello@everydaystatistics.com</a> if the problem persists.
            </p>
          )}
          <div class="eds-subscribed__actions">
            <a href="/" class="btn btn--secondary">Back to home</a>
          </div>
        </>
      ) : (
        <>
          <div class="eyebrow">You're signed up</div>
          <h1>Day 1 is on its way.</h1>
          <p>
            Over the next 44 days you'll receive one unit from the curriculum each day — complete,
            unedited, free.
          </p>
          <p>
            While you're waiting, the full curriculum is available to read any time on the site.
          </p>
          <div class="eds-subscribed__actions">
            <a href="/unit/0-1" class="btn btn--primary">
              Start unit 0.1 now
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="9 6 15 12 9 18"/>
              </svg>
            </a>
            <a href="/curriculum" class="btn btn--secondary">Browse the curriculum</a>
          </div>
        </>
      )}

    </div>
  </div>
</Base>
