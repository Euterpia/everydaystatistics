---
import Base from '../layouts/Base.astro';
const error = Astro.url.searchParams.get('error');
---

<Base title="You're signed up — Everyday Statistics">
  <div class="container" style="max-width: 600px; padding: 5rem 1.5rem; text-align: center;">

    {error ? (
      <>
        <div style="font-size: 2.5rem; margin-bottom: 1rem;">⚠</div>
        <h1 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 1rem;">Something went wrong</h1>
        {error === 'invalid' && (
          <p style="color: var(--text-muted); margin-bottom: 2rem;">
            That doesn't look like a valid email address. Please go back and try again.
          </p>
        )}
        {error !== 'invalid' && (
          <p style="color: var(--text-muted); margin-bottom: 2rem;">
            There was a problem processing your signup. Please try again in a moment, or email
            <a href="mailto:hello@everydaystatistics.com">hello@everydaystatistics.com</a> if the problem persists.
          </p>
        )}
        <a href="/" class="btn btn--primary">← Back to home</a>
      </>
    ) : (
      <>
        <div style="font-size: 2.5rem; margin-bottom: 1rem;">✓</div>
        <h1 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 1rem;">You're signed up.</h1>
        <p style="color: var(--text-muted); line-height: 1.7; margin-bottom: 0.75rem;">
          Day 1 is on its way. Over the next 44 days you'll receive one unit from the curriculum each day — complete, unedited, free.
        </p>
        <p style="color: var(--text-muted); line-height: 1.7; margin-bottom: 2rem;">
          While you're waiting, the full curriculum is available to read any time on the site.
        </p>
        <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
          <a href="/unit/0-1" class="btn btn--primary">Start Unit 0.1 now →</a>
          <a href="/curriculum" class="btn btn--secondary">Browse the curriculum</a>
        </div>
      </>
    )}

  </div>
</Base>
